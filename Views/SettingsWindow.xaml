<ctrl:ThemedWindow x:Class="ClaudeAccountSwitcher.Views.SettingsWindow"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:ctrl="clr-namespace:ClaudeAccountSwitcher.Controls"
                   xmlns:loc="clr-namespace:ClaudeAccountSwitcher.Localization"
                   Title="{loc:Loc SettingsTitle}"
                   Width="470" SizeToContent="Height"
                   ResizeMode="NoResize"
                   ShowInTaskbar="False"
                   WindowStartupLocation="CenterOwner"
                   Style="{DynamicResource ThemedWindowStyle}">
    <StackPanel Margin="24,20">
        <TextBlock Text="{loc:Loc SetLangHeader}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource WhiteBrush}" />
        <TextBlock Text="{loc:Loc SetLangDesc}" Margin="0,2,0,8" Foreground="{DynamicResource SageMistBrush}" />
        <ComboBox Width="240" HorizontalAlignment="Left"
                  ItemsSource="{Binding Languages}"
                  DisplayMemberPath="Display"
                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}" />

        <Border Height="1" Background="{DynamicResource CharcoalAshBrush}" Margin="0,20" />

        <TextBlock Text="{loc:Loc SetShellHeader}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource WhiteBrush}" />
        <TextBlock Text="{loc:Loc SetShellDesc}" Margin="0,2,0,8" Foreground="{DynamicResource SageMistBrush}" />
        <ComboBox Width="240" HorizontalAlignment="Left"
                  ItemsSource="{Binding Shells}"
                  SelectedItem="{Binding SelectedShell, Mode=TwoWay}" />

        <Border Height="1" Background="{DynamicResource CharcoalAshBrush}" Margin="0,20" />

        <TextBlock Text="{loc:Loc SetSkipHeader}" FontSize="14" FontWeight="SemiBold"
                   Foreground="{DynamicResource WhiteBrush}" />
        <TextBlock Margin="0,2,0,10" Foreground="{DynamicResource SageMistBrush}">
            <Run Text="{loc:Loc SetSkipCurrent}" /><Run Text="{Binding SkipPermissionsState, Mode=OneWay}" />
        </TextBlock>
        <Button Content="{loc:Loc SetSkipReset}" HorizontalAlignment="Left" Padding="12,6"
                Command="{Binding ResetSkipPermissionsCommand}"
                IsEnabled="{Binding CanResetSkipPermissions}" />

        <Grid Margin="0,24,0,0">
            <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource SageMistBrush}"
                       Text="{Binding Version, Mode=OneWay}" />
            <Button Content="{loc:Loc SetClose}" HorizontalAlignment="Right"
                    MinWidth="84" Height="30" IsDefault="True" IsCancel="True" />
        </Grid>
    </StackPanel>
</ctrl:ThemedWindow>

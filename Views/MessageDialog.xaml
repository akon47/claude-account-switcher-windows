<ctrl:ThemedWindow x:Class="ClaudeAccountSwitcher.Views.MessageDialog"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:ctrl="clr-namespace:ClaudeAccountSwitcher.Controls"
                   xmlns:b="clr-namespace:ClaudeAccountSwitcher.Behaviors"
                   Title="{Binding Title}"
                   Width="430" SizeToContent="Height"
                   ResizeMode="NoResize"
                   ShowInTaskbar="False"
                   WindowStartupLocation="CenterOwner"
                   Style="{DynamicResource ThemedWindowStyle}"
                   b:DialogResultBehavior.Result="{Binding DialogResult}">
    <StackPanel Margin="22,20">
        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                   Foreground="{DynamicResource WhiteBrush}" LineHeight="20" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="{Binding OkText}" MinWidth="84" Height="30" IsDefault="True" Command="{Binding AcceptCommand}"
                    Margin="0,0,8,0" Style="{DynamicResource AccentButtonStyle}" />
            <Button Content="{Binding CancelText}" MinWidth="84" Height="30" IsCancel="True"
                    Visibility="{Binding CancelVisibility}" />
        </StackPanel>
    </StackPanel>
</ctrl:ThemedWindow>

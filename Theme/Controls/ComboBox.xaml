<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Theme/Brushes.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Theme/Effects.xaml" />
    </ResourceDictionary.MergedDictionaries>
<!-- ======================= ComboBox helper resources ======================= -->

<!-- Chevron geometry (chevron path) -->
<PathGeometry x:Key="Cmb_ChevronDownGeometry"
              Figures="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z" />

<!-- ToggleButton sub-style: borderless/transparent so the outer Border draws the chrome.
     Carries the chevron Path; rotates 180deg when the drop-down is open. -->
<Style x:Key="Cmb_ToggleButtonStyle" TargetType="{x:Type ToggleButton}">
    <Setter Property="Focusable" Value="False" />
    <Setter Property="ClickMode" Value="Press" />
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Stretch" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="{x:Type ToggleButton}">
                <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                    <Path x:Name="Cmb_Chevron"
                          Width="12"
                          Height="12"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Data="{StaticResource Cmb_ChevronDownGeometry}"
                          Fill="{StaticResource SageMistBrush}"
                          RenderTransformOrigin="0.5,0.5"
                          Stretch="Uniform">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="Cmb_ChevronRotate" Angle="0" />
                        </Path.RenderTransform>
                    </Path>
                </Border>
                <ControlTemplate.Triggers>
                    <!-- Drop-down open (IsChecked is bound to IsDropDownOpen): flip the chevron. -->
                    <Trigger Property="IsChecked" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Cmb_Chevron"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                     To="180" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Cmb_Chevron"
                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                     To="0" Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<!-- ComboBoxItem-scope ScrollViewer is the stock one; no helper needed. -->

<!-- ============================ ComboBoxItem ============================ -->
<Style TargetType="{x:Type ComboBoxItem}">
    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                <Border x:Name="Cmb_ItemBorder"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="4"
                        SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Cmb_ItemBorder" Property="Background" Value="{StaticResource DeepAzureBrushOpacity50}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="Cmb_ItemBorder" Property="Background" Value="{StaticResource AzureBrushOpacity30}" />
                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{StaticResource SageMistBrush}" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<!-- ============================== ComboBox ============================== -->
<Style TargetType="{x:Type ComboBox}">
    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
    <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource DimGrayBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="6,4" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="MinWidth" Value="40" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    <Setter Property="TextElement.Foreground" Value="{StaticResource WhiteBrush}" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="{x:Type ComboBox}">
                <Grid x:Name="Cmb_LayoutRoot">
                    <!-- Outer chrome border (clipped border) -->
                    <Border x:Name="Cmb_BorderRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            ClipToBounds="True"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Toggle area: full-surface ToggleButton draws the chevron in column 1 -->
                            <ToggleButton x:Name="Cmb_ToggleButton"
                                          Grid.Column="0"
                                          Grid.ColumnSpan="2"
                                          Padding="6,0"
                                          HorizontalContentAlignment="Right"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Style="{StaticResource Cmb_ToggleButtonStyle}" />

                            <!-- Selected value (non-editable) -->
                            <ContentPresenter x:Name="Cmb_ContentSite"
                                              Grid.Column="0"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              IsHitTestVisible="False"
                                              SnapsToDevicePixels="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />

                            <!-- Editable text box (optional; shown only when IsEditable=True) -->
                            <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Margin="{TemplateBinding Padding}"
                                     Padding="0"
                                     VerticalContentAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     CaretBrush="{StaticResource WhiteBrush}"
                                     Focusable="True"
                                     Foreground="{StaticResource WhiteBrush}"
                                     IsReadOnly="{Binding IsReadOnly, RelativeSource={RelativeSource TemplatedParent}}"
                                     SelectionBrush="{StaticResource AzureBrushOpacity50}"
                                     Visibility="Collapsed" />

                            <!-- Spacer column reserves room for the chevron drawn by the ToggleButton -->
                            <Border Grid.Column="1" Width="22" IsHitTestVisible="False" />
                        </Grid>
                    </Border>

                    <!-- Drop-down popup -->
                    <Popup x:Name="PART_Popup"
                           AllowsTransparency="True"
                           Focusable="False"
                           IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                           Placement="Bottom"
                           PlacementTarget="{Binding ElementName=Cmb_BorderRoot}"
                           PopupAnimation="Slide">
                        <!-- Transparent outer border leaves room for the drop shadow -->
                        <Border x:Name="Cmb_PopupShadowHost"
                                Margin="5"
                                Padding="0,3"
                                Background="Transparent"
                                Effect="{StaticResource DefaultDropShadowEffect}">
                            <Border x:Name="Cmb_DropDownBorder"
                                    MinWidth="{Binding ActualWidth, ElementName=Cmb_BorderRoot}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{StaticResource CharcoalGrayBrush}"
                                    BorderBrush="{StaticResource DimGrayBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    ClipToBounds="True"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer Margin="0,4"
                                              Padding="2"
                                              SnapsToDevicePixels="True">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                </ScrollViewer>
                            </Border>
                        </Border>
                    </Popup>
                </Grid>

                <ControlTemplate.Triggers>
                    <!-- Make room rules & editable swap -->
                    <Trigger Property="IsEditable" Value="True">
                        <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                        <Setter TargetName="Cmb_ContentSite" Property="Visibility" Value="Collapsed" />
                        <Setter Property="IsTabStop" Value="False" />
                    </Trigger>

                    <!-- Hover: border AzureMistBrush -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Cmb_BorderRoot" Property="BorderBrush" Value="{StaticResource AzureMistBrush}" />
                    </Trigger>

                    <!-- Keyboard focus / drop-down open: border AzureBrush -->
                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter TargetName="Cmb_BorderRoot" Property="BorderBrush" Value="{StaticResource AzureBrush}" />
                    </Trigger>
                    <Trigger Property="IsDropDownOpen" Value="True">
                        <Setter TargetName="Cmb_BorderRoot" Property="BorderBrush" Value="{StaticResource AzureBrush}" />
                    </Trigger>

                    <!-- Empty drop-down minimum height -->
                    <Trigger Property="HasItems" Value="False">
                        <Setter TargetName="Cmb_DropDownBorder" Property="MinHeight" Value="48" />
                    </Trigger>

                    <!-- Disabled -->
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="Cmb_BorderRoot" Property="Background" Value="{StaticResource ControlBackgroundBrush}" />
                        <Setter TargetName="Cmb_BorderRoot" Property="BorderBrush" Value="{StaticResource CharcoalAshBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource SageMistBrush}" />
                        <Setter TargetName="Cmb_LayoutRoot" Property="Opacity" Value="0.6" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>
</ResourceDictionary>

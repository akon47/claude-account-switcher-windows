<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Theme/Brushes.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Theme/Effects.xaml" />
    </ResourceDictionary.MergedDictionaries>
<!-- ===================================================================
     Default Button (IMPLICIT) - dark charcoal button
     CornerRadius 4, CharcoalAsh bg, White fg, 1px subtle border,
     FontSize 12. Self-contained: Border + ContentPresenter, with a
     white overlay border for the MouseOver hover (opacity .1).
     ==================================================================== -->
<Style TargetType="{x:Type Button}">
    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
    <Setter Property="Background" Value="{StaticResource CharcoalAshBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource DimGrayBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="MinWidth" Value="80" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
                <Grid>
                    <!-- Base surface -->
                    <Border x:Name="Btn_Bg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="Btn_Content"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          SnapsToDevicePixels="True" />
                    </Border>

                    <!-- White hover overlay (white @ opacity .1 on MouseOver) -->
                    <Border x:Name="Btn_HoverOverlay"
                            Background="{StaticResource WhiteBrush}"
                            CornerRadius="4"
                            IsHitTestVisible="False"
                            Opacity="0" />

                    <!-- Keyboard focus ring (1px Azure) -->
                    <Border x:Name="Btn_FocusRing"
                            BorderBrush="{StaticResource AzureBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            IsHitTestVisible="False"
                            Opacity="0" />
                </Grid>

                <ControlTemplate.Triggers>
                    <!-- MouseOver: reveal subtle white overlay (-> slightly lighter) -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Btn_HoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.1"
                                                     Duration="0:0:0.15" />
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Btn_HoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.25" />
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>

                    <!-- Pressed: darker via Azure-tinted overlay (AzureBrushOpacity20) -->
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Btn_Bg" Property="Background" Value="{StaticResource AzureBrushOpacity20}" />
                        <Setter TargetName="Btn_HoverOverlay" Property="Opacity" Value="0" />
                    </Trigger>

                    <!-- Keyboard focus: show Azure focus ring -->
                    <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter TargetName="Btn_FocusRing" Property="Opacity" Value="1" />
                    </Trigger>

                    <!-- Disabled: opacity .4 + muted SageMist foreground -->
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="Btn_Bg" Property="Opacity" Value="0.4" />
                        <Setter Property="Foreground" Value="{StaticResource SageMistBrush}" />
                        <Setter Property="Cursor" Value="Arrow" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<!-- ===================================================================
     Accent Button (KEYED) - primary / affirmative
     BasedOn default; Azure background, DeepAzure hover, White fg.
     Re-templated so hover swaps to DeepAzure (rather than white overlay)
     to match an accent "filled" button feel.
     ==================================================================== -->
<Style x:Key="AccentButtonStyle"
       BasedOn="{StaticResource {x:Type Button}}"
       TargetType="{x:Type Button}">
    <Setter Property="Background" Value="{StaticResource AzureBrush}" />
    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource AzureBrush}" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
                <Grid>
                    <Border x:Name="Btn_AccentBg"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"
                                          SnapsToDevicePixels="True" />
                    </Border>

                    <!-- Keyboard focus ring (1px Azure mist for contrast on azure bg) -->
                    <Border x:Name="Btn_AccentFocusRing"
                            BorderBrush="{StaticResource AzureMistBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            IsHitTestVisible="False"
                            Opacity="0" />
                </Grid>

                <ControlTemplate.Triggers>
                    <!-- MouseOver: DeepAzure -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Btn_AccentBg" Property="Background" Value="{StaticResource DeepAzureBrush}" />
                        <Setter TargetName="Btn_AccentBg" Property="BorderBrush" Value="{StaticResource DeepAzureBrush}" />
                    </Trigger>

                    <!-- Pressed: darker tint -->
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Btn_AccentBg" Property="Background" Value="{StaticResource AzureBrushOpacity20}" />
                        <Setter TargetName="Btn_AccentBg" Property="BorderBrush" Value="{StaticResource DeepAzureBrush}" />
                    </Trigger>

                    <!-- Keyboard focus ring -->
                    <Trigger Property="IsKeyboardFocused" Value="True">
                        <Setter TargetName="Btn_AccentFocusRing" Property="Opacity" Value="1" />
                    </Trigger>

                    <!-- Disabled: opacity .4 + SageMist foreground -->
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="Btn_AccentBg" Property="Opacity" Value="0.4" />
                        <Setter Property="Foreground" Value="{StaticResource SageMistBrush}" />
                        <Setter Property="Cursor" Value="Arrow" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<!-- ===================================================================
     Icon Button (KEYED) - flat, borderless, square. Hosts a Segoe Fluent
     Icons glyph as Content. Transparent bg, CharcoalAsh hover. Used for
     toolbar actions (refresh / settings) and inline row actions.
     ==================================================================== -->
<Style x:Key="IconButtonStyle" TargetType="{x:Type Button}">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource SoftAshBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
                <Border x:Name="IconBtn_Bg"
                        Background="{TemplateBinding Background}"
                        CornerRadius="4"
                        SnapsToDevicePixels="True">
                    <!-- Icon font applied only to the glyph (NOT Button.FontFamily) so it
                         doesn't inherit into the ToolTip and break Korean text. -->
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      TextElement.FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="IconBtn_Bg" Property="Background" Value="{StaticResource CharcoalAshBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="IconBtn_Bg" Property="Background" Value="{StaticResource DimGrayBrush}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.4" />
                        <Setter Property="Cursor" Value="Arrow" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<!-- Inline row delete (KEYED) - small icon button; glyph turns Vermilion on hover. -->
<Style x:Key="DeleteRowButtonStyle"
       BasedOn="{StaticResource IconButtonStyle}"
       TargetType="{x:Type Button}">
    <Setter Property="Width" Value="24" />
    <Setter Property="Height" Value="24" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{StaticResource SageMistBrush}" />
    <!-- Style trigger wins over the template's hover foreground (White) -> red X. -->
    <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Foreground" Value="{StaticResource VermilionBrush}" />
        </Trigger>
    </Style.Triggers>
</Style>
</ResourceDictionary>

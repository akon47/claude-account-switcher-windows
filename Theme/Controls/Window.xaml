<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Theme/Brushes.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Theme/Effects.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--  Caption button glyphs (10x10, filled; even-odd outlines for max/restore).  -->
    <Geometry x:Key="Win_MinimizeGlyph">M0,5 L10,5 L10,6 L0,6 Z</Geometry>
    <Geometry x:Key="Win_MaximizeGlyph">F0 M0,0 L10,0 L10,10 L0,10 Z M1.5,1.5 L8.5,1.5 L8.5,8.5 L1.5,8.5 Z</Geometry>
    <Geometry x:Key="Win_RestoreGlyph">F0 M3,0 L10,0 L10,7 L3,7 Z M4,1 L9,1 L9,6 L4,6 Z M0,3 L7,3 L7,10 L0,10 Z M1,4 L6,4 L6,9 L1,9 Z</Geometry>
    <Geometry x:Key="Win_CloseGlyph">M0,1 L1,0 L10,9 L9,10 Z M9,0 L10,1 L1,10 L0,9 Z</Geometry>
<!--  Caption button style for the custom dark title bar (Minimize / Maximize / Restore / Close).  -->
<!--  Flat, transparent; hover = CharcoalAshBrush. The CLOSE button overrides hover to VermilionBrush  -->
<!--  via its own trigger inline on the button (see ThemedWindowStyle template).  -->
<Style x:Key="Win_CaptionButtonStyle" TargetType="{x:Type Button}">
    <Setter Property="Width" Value="45" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{StaticResource SoftAshBrush}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
                <Border x:Name="Win_CaptionButtonBorder"
                        Background="{TemplateBinding Background}"
                        SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Win_CaptionButtonBorder" Property="Background" Value="{StaticResource CharcoalAshBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Win_CaptionButtonBorder" Property="Background" Value="{StaticResource DimGrayBrush}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Foreground" Value="{StaticResource SageMistBrush}" />
                        <Setter Property="Opacity" Value="0.5" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<!--  Close-button variant: identical to Win_CaptionButtonStyle but hover turns VermilionBrush (red).  -->
<Style x:Key="Win_CloseCaptionButtonStyle"
       BasedOn="{StaticResource Win_CaptionButtonStyle}"
       TargetType="{x:Type Button}">
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
                <Border x:Name="Win_CloseButtonBorder"
                        Background="{TemplateBinding Background}"
                        SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Win_CloseButtonBorder" Property="Background" Value="{StaticResource VermilionBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Win_CloseButtonBorder" Property="Background" Value="{StaticResource CrimsonBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>

<!--  WindowChrome definitions: Normal (resizable) and Maximized (no resize border).  -->
<WindowChrome x:Key="Win_NormalWindowChrome"
              CaptionHeight="32"
              CornerRadius="0"
              GlassFrameThickness="0"
              ResizeBorderThickness="6"
              UseAeroCaptionButtons="False" />

<WindowChrome x:Key="Win_MaximizedWindowChrome"
              CaptionHeight="32"
              CornerRadius="0"
              GlassFrameThickness="0"
              ResizeBorderThickness="0"
              UseAeroCaptionButtons="False" />

<!--  Themed dark Window with custom WindowChrome title bar.  -->
<!--  Assumes the base window class registers CommandBindings for the SystemCommands routed commands.  -->
<Style x:Key="ThemedWindowStyle" TargetType="{x:Type Window}">
    <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}" />
    <Setter Property="Foreground" Value="{StaticResource WhiteBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource CharcoalAshBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="WindowChrome.WindowChrome" Value="{StaticResource Win_NormalWindowChrome}" />
    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="{x:Type Window}">
                <Border x:Name="Win_LayoutRoot"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                    <Grid x:Name="Win_ContentMargin">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Title bar  -->
                        <Border Grid.Row="0"
                                Background="{StaticResource WindowBackgroundBrush}"
                                BorderBrush="{StaticResource CharcoalAshBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Window title (left)  -->
                                <TextBlock Grid.Column="0"
                                           Margin="12,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource WhiteBrush}"
                                           Text="{TemplateBinding Title}"
                                           TextTrimming="CharacterEllipsis" />

                                <!--  Caption buttons (right)  -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <!--  Minimize  -->
                                    <Button x:Name="Win_MinimizeButton"
                                            Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            Style="{StaticResource Win_CaptionButtonStyle}"
                                            ToolTip="Minimize"
                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                        <Path Width="10"
                                              Height="10"
                                              Data="{StaticResource Win_MinimizeGlyph}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                              Stretch="Uniform" />
                                    </Button>

                                    <!--  Maximize  -->
                                    <Button x:Name="Win_MaximizeButton"
                                            Command="{x:Static SystemCommands.MaximizeWindowCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            Style="{StaticResource Win_CaptionButtonStyle}"
                                            ToolTip="Maximize"
                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                        <Path Width="10"
                                              Height="10"
                                              Data="{StaticResource Win_MaximizeGlyph}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                              Stretch="Uniform" />
                                    </Button>

                                    <!--  Restore (shown only when maximized)  -->
                                    <Button x:Name="Win_RestoreButton"
                                            Command="{x:Static SystemCommands.RestoreWindowCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            Style="{StaticResource Win_CaptionButtonStyle}"
                                            ToolTip="Restore"
                                            Visibility="Collapsed"
                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                        <Path Width="10"
                                              Height="10"
                                              Data="{StaticResource Win_RestoreGlyph}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                              Stretch="Uniform" />
                                    </Button>

                                    <!--  Close  -->
                                    <Button x:Name="Win_CloseButton"
                                            Command="{x:Static SystemCommands.CloseWindowCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            Style="{StaticResource Win_CloseCaptionButtonStyle}"
                                            ToolTip="Close"
                                            WindowChrome.IsHitTestVisibleInChrome="True">
                                        <Path Width="10"
                                              Height="10"
                                              Data="{StaticResource Win_CloseGlyph}"
                                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                              Stretch="Uniform" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!--  Window body  -->
                        <Border Grid.Row="1" Background="{StaticResource WindowBackgroundBrush}">
                            <AdornerDecorator>
                                <ContentPresenter />
                            </AdornerDecorator>
                        </Border>
                    </Grid>
                </Border>

                <ControlTemplate.Triggers>
                    <!--  Maximized: swap chrome, hide maximize / show restore, add content margin so it doesn't overflow.  -->
                    <Trigger Property="WindowState" Value="Maximized">
                        <Setter Property="WindowChrome.WindowChrome" Value="{StaticResource Win_MaximizedWindowChrome}" />
                        <Setter TargetName="Win_ContentMargin" Property="Margin" Value="7" />
                        <Setter TargetName="Win_MaximizeButton" Property="Visibility" Value="Collapsed" />
                        <Setter TargetName="Win_RestoreButton" Property="Visibility" Value="Visible" />
                    </Trigger>

                    <!--  CanMinimize: disable maximize.  -->
                    <Trigger Property="ResizeMode" Value="CanMinimize">
                        <Setter TargetName="Win_MaximizeButton" Property="IsEnabled" Value="False" />
                    </Trigger>

                    <!--  NoResize: hide min / max / restore.  -->
                    <Trigger Property="ResizeMode" Value="NoResize">
                        <Setter TargetName="Win_MinimizeButton" Property="Visibility" Value="Collapsed" />
                        <Setter TargetName="Win_MaximizeButton" Property="Visibility" Value="Collapsed" />
                        <Setter TargetName="Win_RestoreButton" Property="Visibility" Value="Collapsed" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>
</ResourceDictionary>
